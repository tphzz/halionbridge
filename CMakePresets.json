{
  "version": 3,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "diagnostics-debug",
      "displayName": "Diagnostics Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-diagnostics",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "HALIONBRIDGE_ENABLE_DIAGNOSTICS": "ON",
        "HALIONBRIDGE_ENABLE_CRASH_DUMPS": "ON"
      }
    },
    {
      "name": "diagnostics-relwithdebinfo",
      "displayName": "Diagnostics RelWithDebInfo",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-relwithdebinfo-diagnostics",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "HALIONBRIDGE_ENABLE_DIAGNOSTICS": "ON",
        "HALIONBRIDGE_ENABLE_CRASH_DUMPS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "diagnostics-debug",
      "configurePreset": "diagnostics-debug"
    },
    {
      "name": "diagnostics-relwithdebinfo",
      "configurePreset": "diagnostics-relwithdebinfo"
    }
  ]
}
